# Copy to .env.local — never commit secrets.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional booking and auth emails
# https://resend.com/docs/send-with-nextjs
RESEND_API_KEY=
# Verified domain in Resend; defaults in code if unset
BOOKINGS_FROM_EMAIL=Rollin Locations <bookings@locations.rollin.video>
# Optional: receive new booking alerts when host email is missing on the listing
ADMIN_HOST_FALLBACK_EMAIL=
